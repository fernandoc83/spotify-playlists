# Copia este archivo a ".env" y rellena con tus credenciales del
# Spotify Developer Dashboard: https://developer.spotify.com/dashboard
#
# 1. Crea una app.
# 2. En "Edit Settings" agrega como Redirect URI EXACTAMENTE:
#       http://127.0.0.1:8888/callback
# 3. Copia el Client ID y Client Secret aquí abajo.

SPOTIPY_CLIENT_ID=tu_client_id_aqui
SPOTIPY_CLIENT_SECRET=tu_client_secret_aqui
SPOTIPY_REDIRECT_URI=http://127.0.0.1:8888/callback

# ---------------------------------------------------------------------------
# Automatización (solo la usa el contenedor Docker / scheduler.py).
# Todas son opcionales: si las borrás, valen los defaults.
# Cambiá esto acá, NO en docker-compose.yml (así no hay conflictos al git pull).
# IMPORTANTE: no pongas comentarios en la misma línea que el valor; Docker los
# toma como parte del valor. Los comentarios van en su propia línea, como acá.
# ---------------------------------------------------------------------------

# diario | semanal | mensual
FRECUENCIA=semanal

# hora local de la corrida (HORA 0-23, MINUTO 0-59)
HORA=9
MINUTO=0

# solo si FRECUENCIA=semanal — 0=lunes … 6=domingo
DIA_SEMANA=0

# solo si FRECUENCIA=mensual — 1-31 (se ajusta si el mes es más corto)
DIA_MES=1

# 1 = corre una vez al levantar el contenedor (además del schedule)
RUN_ON_START=0

# zona horaria, para que HORA sea tu hora local
TZ=America/Argentina/Buenos_Aires
